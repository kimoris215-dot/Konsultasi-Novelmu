                <label id="lbl-idea" class="block text-xs font-bold text-indigo-300 uppercase mb-2">Ide Cerita</label>
                <textarea id="user-idea" rows="3" class="w-full bg-slate-900 border border-slate-700 rounded-2xl p-4 text-sm outline-none focus:border-indigo-500" placeholder="Masukkan ide dasar..."></textarea>
            </div>
            
            <div>
                <label id="lbl-suggest" class="block text-xs font-bold text-indigo-300 uppercase mb-2">Saran Tambahan</label>
                <textarea id="user-suggestion" rows="2" class="w-full bg-slate-900 border border-slate-700 rounded-2xl p-4 text-sm outline-none focus:border-indigo-500" placeholder="Ingin alur seperti apa?"></textarea>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <select id="total-chapters" class="bg-slate-900 border border-slate-700 rounded-xl p-3 text-sm">
                    <option value="5">5 Bab</option>
                    <option value="10">10 Bab</option>
                    <option value="20">20 Bab</option>
                </select>
                <button onclick="generate()" id="btn-gen" class="bg-indigo-600 rounded-xl font-bold text-sm hover:bg-indigo-700 transition-all">Buat Outline</button>
            </div>
        </div>

        <div id="result" class="hidden glass p-6 rounded-3xl space-y-6">
            <div class="border-b border-slate-700 pb-4">
                <h3 id="res-setting" class="text-indigo-400 font-bold mb-1">Latar & Dunia</h3>
                <p id="display-setting" class="text-sm text-slate-300 italic"></p>
            </div>
            <div id="display-chapters" class="space-y-4"></div>
        </div>
    </div>

