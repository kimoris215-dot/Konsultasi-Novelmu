<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NovelConsult - Lab Penulis</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #0f172a; color: #f1f5f9; padding-bottom: 80px; }
        .glass { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); }
        .hidden-page { display: none; }
        .nav-active { color: #818cf8; border-top: 3px solid #818cf8; }
    </style>
</head>
<body>

    <div id="home-page" class="p-4 md:p-8 max-w-2xl mx-auto space-y-6">
        <header class="text-center py-6">
            <h1 id="title" class="text-3xl font-extrabold text-indigo-400">NovelConsult ✍️</h1>
            <p id="subtitle" class="text-slate-400 text-sm">Rancang mahakaryamu di sini</p>
        </header>

        <div class="glass p-6 rounded-3xl space-y-4 shadow-2xl">
